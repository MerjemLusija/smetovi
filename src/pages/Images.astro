---
import PageLayout from "../layouts/PageLayout.astro";

const images = [
  "/images/slike/_smetoviImage1.png",
  "/images/slike/_smetoviImage2.png",
  "/images/slike/_smetoviImage3.png",
  "/images/slike/_smetoviImage4.png",
  "/images/slike/_smetoviImage5.png",
  "/images/slike/_smetoviImage6.png",
];
---

<PageLayout>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <main class="imagesMain">
    {images.map((imageSrc, index) => (
        <div
            class="comicPanel"
            data-image-index={index}
            onclick={`openSlider(${index})`}
        >
          <img src={imageSrc} alt={`img${index + 1}`} />
        </div>
    ))}
  </main>

  <!-- Image Slider Modal -->
  <div id="imageSlider" class="slider-modal">
    <div class="slider-overlay" onclick="closeSlider()"></div>
    <button class="slider-close" onclick="closeSlider()" aria-label="Close">
      ×
    </button>
    <button class="slider-prev" onclick="changeSlide(-1)" aria-label="Previous">
      <span class="material-symbols-outlined">
        arrow_back_ios
      </span>
    </button>
    <button class="slider-next" onclick="changeSlide(1)" aria-label="Next">
      <span class="material-symbols-outlined">
        arrow_forward_ios
      </span>
    </button>
    <div class="slider-content">
      <img id="sliderImage" src="" alt="Slider image" />
    </div>
  </div>
</PageLayout>

<style>
  body {
    margin: 0;
    font-family: 'Exo 2', sans-serif;
    background: #f8fafc; /* light slate background */
  }

  .imagesMain {
    column-count: 3;
    column-gap: 1rem;
    padding: 6rem 2rem 2rem;
    max-width: 1200px;
    margin: auto;
    min-height: 100vh;
  }

  .gallery-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  /* Masonry-like CSS Grid approach */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    grid-auto-rows: 250px;
    grid-gap: 20px;
    grid-auto-flow: dense;
  }

  /* Make some items span 2 rows for masonry effect */
  .gallery-item:nth-child(2n) {
    grid-row: span 2;
  }
  .gallery-item:nth-child(5n) {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease;
    cursor: pointer;
  }

  .comicPanel:hover {
    transform: scale(1.03);
    z-index: 1;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Slider Modal Styles */
  .slider-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .slider-modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
  }

  .slider-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
  }

  .slider-content {
    position: relative;
    z-index: 1001;
    max-width: 90%;
    max-height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .slider-content img {
    width: auto;
    height: 80vh;
    max-width: 90vw;
    object-fit: contain;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .slider-close {
    position: absolute;
    top: 50px;
    right: 30px;
    z-index: 1002;
    color: white;
    font-size: 2.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .slider-close:hover {
    transform: rotate(90deg);
  }

  .slider-prev,
  .slider-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1002;
    color: white;
    font-size: 3rem;
    width: 60px;
    height: 60px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    user-select: none;
  }

  .slider-prev {
    left: 30px;
  }

  .slider-next {
    right: 30px;
  }

  .slider-prev:hover,
  .slider-next:hover {
    transform: translateY(-50%) scale(1.1);
  }

  .slider-prev:active,
  .slider-next:active {
    transform: translateY(-50%) scale(0.95);
  }

  @media (max-width: 1000px) {
    .imagesMain {
      column-count: 2;
    }

    .slider-prev,
    .slider-next {
      width: 50px;
      height: 50px;
      font-size: 45px;
    }

    .slider-prev {
      left: 15px;
    }

    .slider-next {
      right: 15px;
    }

    .slider-close {
      top: 60px;
      right: 15px;
      width: 40px;
      height: 40px;
      font-size: 2rem;
    }
  }

  @media (max-width: 600px) {
    .imagesMain {
      column-count: 1;
    }

    .slider-content {
      max-width: 95%;
    }

    .slider-content img {
      height: 70vh;
    }

    .slider-prev,
    .slider-next {
      width: 40px;
      height: 40px;
      font-size: 2rem;
    }

    .slider-prev {
      left: 10px;
    }

    .slider-next {
      right: 10px;
    }

    .slider-close {
      top: 60px;
      right: 10px;
    }
  }
</style>

<script is:inline define:vars={{ images }}>

  let currentSlideIndex = 0;
  const sliderModal = document.getElementById("imageSlider");
  const sliderImage = document.getElementById("sliderImage");

  function openSlider(index) {
    currentSlideIndex = index;
    updateSliderImage();
    sliderModal?.classList.add("active");
    document.body.style.overflow = "hidden";
  }

  function closeSlider() {
    sliderModal?.classList.remove("active");
    document.body.style.overflow = "";
  }

  function changeSlide(direction) {
    currentSlideIndex += direction;

    if (currentSlideIndex < 0) {
      currentSlideIndex = images.length - 1;
    } else if (currentSlideIndex >= images.length) {
      currentSlideIndex = 0;
    }

    updateSliderImage();
  }

  window.openSlider = openSlider;
  window.closeSlider = closeSlider;
  window.changeSlide = changeSlide;

  function updateSliderImage() {
    if (sliderImage) {
      sliderImage.src = images[currentSlideIndex];
    }
  }

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    if (!sliderModal?.classList.contains("active")) return;

    if (e.key === "Escape") {
      closeSlider();
    } else if (e.key === "ArrowLeft") {
      changeSlide(-1);
    } else if (e.key === "ArrowRight") {
      changeSlide(1);
    }
  });

  // Prevent slider navigation when clicking on the image itself
  sliderImage?.addEventListener("click", (e) => {
    e.stopPropagation();
  });
</script>

